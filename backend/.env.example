APP_NAME=Closira Enquiry API
APP_VERSION=1.0.0
DEBUG=True

# SQLite database URL
DB_URL=sqlite:///./data/closira.db
DB_ECHO=False

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File paths for SOP rules and responses
SOP_KEYWORDS_FILE=./data/sop_rules.json
SUGGESTED_RESPONSES_FILE=./data/suggested_responses.json

# Other settings
MAX_CONVERSATION_HISTORY=50
ESCALATION_PRIORITY_MIN=3
CORS_ORIGINS=["*"]
